  # PersonHistory
  - job: Job_PersonHistory
    displayName: 'PersonHistory'
    condition: contains(variables['selectedTests'], 'PersonHistory')
    pool:
      name: Interactive
    timeoutInMinutes: 480
    steps:
    - checkout: none
    - task: TriggerBuild@4
      displayName: 'Trigger PersonHistory Pipeline'
      inputs:
        definitionIsInCurrentTeamProject: true
        buildDefinition: 'Test_Auto_STND_Regression_PersonHistory'
        queueBuildForUserThatTriggeredBuild: true
        waitForQueuedBuildsToFinish: true
        buildParameters: 'xPath: $(tPath)\PersonHistory, Browser: ${{ parameters.Browser }}, Environment: ${{ parameters.Environment }}'
        password: $(sharedpat)
      continueOnError: true
  
