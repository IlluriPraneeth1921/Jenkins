variables:
  - name: orgUrl
    value: $(System.TeamFoundationCollectionUri)
  - name: projectName
    value: $(System.TeamProject)

stages:
#############################################################################
# STAGE 1: SETUP AND VALIDATION
#############################################################################
- stage: Setup
  displayName: '🔧 Setup and Validation'
  jobs:
  - job: ValidateAndPrepare
    displayName: 'Validate Parameters and Create Target Directory'
    pool:
      name: Interactive
    timeoutInMinutes: 30
    steps:
    - checkout: none
    
    - powershell: |
        Write-Host "========================================="
        Write-Host "PARAMETER VALIDATION & TEST SELECTION"
        Write-Host "========================================="
        
        # Define all available tests and their child pipeline names
        $allTests = @(
          'PersonHistory', 'ProfilePicture', 'MessageModule', 'ProgressNote',
          'Notification', 'PostCrisisReview', 'ProgramApplication', 'ProgramConfig',
          'Announcement', 'StaffModule', 'OrganizationModule', 'PersonProfile',
          'ReportableEvents', 'ServiceDef_01', 'ServiceDef_02', 'ProgramEnrollmentNew',
          'SystemAttachments', 'AttachmentsModule', 'BMP', 'BulkAssignment',
          'CrisisBedIntakePacket', 'CrisisHousingAssessment', 'CrisisIntake',
          'CrisisHomeIntake', 'CrisisTemporaryHousing', 'CrisisHousingAgreement',
          'DeathandMortality', 'EmergencyDisposition', 'GrievanceAppeal_01',
          'GrievanceAppeal_02', 'Help', 'LocationsModule', 'IndividualSupportTeam',
          'MiniPCP', 'ConfigDashboard', 'PersonMaintenance'
        )

        $testDefinitions = @{
          'PersonHistory' = 'Test_Auto_STND_Regression_PersonHistory'
          'ProfilePicture' = 'Test_Auto_STND_Regression_ProfilePicture'
          'MessageModule' = 'Test_Auto_STND_Regression_MessageModule'
          'ProgressNote' = 'Test_Auto_STND_Regression_ProgressNote'
          'Notification' = 'Test_Auto_STND_Regression_Notification'
          'PostCrisisReview' = 'Test_Auto_STND_Regression_PostCrisisReview'
          'ProgramApplication' = 'Test_Auto_STND_Regression_ProgramApplication'
          'ProgramConfig' = 'Carity_STD_F1_RegressionTest_ProgramConfig'
          'Announcement' = 'Test_Auto_STND_Regression_Annoucement'
          'StaffModule' = 'Test_Auto_STND_Regression_StaffModule'
          'OrganizationModule' = 'Test_Auto_Regression_OrganizationModule_CommonBrowser'
          'PersonProfile' = 'Carity_Std_QC_RegressionTest_Person Profile (SOGI)'
          'ReportableEvents' = 'Test_Auto_STND_Regression_Reportable_Events'
          'ServiceDef_01' = 'Test_Auto_STND_Regression_ServiceDef_01'
          'ServiceDef_02' = 'Test_Auto_STND_Regression_ServiceDef_02'
          'ProgramEnrollmentNew' = 'Carity_Std_f1_RegressionTest_ProgramEnrollmentNew'
          'SystemAttachments' = 'Test_Auto_STND_Regression_SystemAttachments'
          'AttachmentsModule' = 'Test_Auto_STND_Regression_AttachmentsModule'
          'BMP' = 'Test_Auto_STND_Regression_BMP'
          'BulkAssignment' = 'Carity_Std_qc_RegressionTest_BulkAssignment'
          'CrisisBedIntakePacket' = 'Carity_STND_RegressionTest_CrisisBedIntakePacket'
          'CrisisHousingAssessment' = 'Carity_STND_RegressionTest_Crisis_Housing_Assessment'
          'CrisisIntake' = 'Carity_STND_RegressionTest_Crisis_Intake'
          'CrisisHomeIntake' = 'Carity_Std_CrisisHomeIntakeModule'
          'CrisisTemporaryHousing' = 'Carity_STND_RegressionTest_Crisis_Temporary_Housing'
          'CrisisHousingAgreement' = 'Carity_STND_RegressionTest_Crisis_Housing_Agreement'
          'DeathandMortality' = 'Test_Auto_STND_Regression_DeathandMortality'
          'EmergencyDisposition' = 'Test_Auto_STND_Regression_EmergencyDisposition'
          'GrievanceAppeal_01' = 'Test_Auto_STND_Regression_GrievanceAppeal_01'
          'GrievanceAppeal_02' = 'Test_Auto_STND_Regression_GrievanceAppeal_02'
          'Help' = 'Test_Auto_STND_Regression_Help'
          'LocationsModule' = 'Test_Auto_STND_Regression_LocationsModule'
          'IndividualSupportTeam' = 'Test_Auto_STND_Regression_IndividualSupportTeam'
          'MiniPCP' = 'Carity_STND_Regression Test_Mini PCP_F1'
          'ConfigDashboard' = 'Carity_STDF1_Config Dashboard'
          'PersonMaintenance' = 'Carity_Std_f1_RegressionTest_PersonMaintenance'
        }
        
        # Predefined test groups
        $smokeTests = @('PersonHistory', 'MessageModule', 'ProgressNote', 'StaffModule', 'OrganizationModule')
        
        $criticalPath = @('PersonProfile', 'ProgramEnrollmentNew', 'ServiceDef_01', 
                         'ProgressNote', 'StaffModule', 'OrganizationModule', 'ReportableEvents')
        
        $crisisModules = @('CrisisBedIntakePacket', 'CrisisHousingAssessment', 'CrisisIntake',
                          'CrisisHomeIntake', 'CrisisTemporaryHousing', 'CrisisHousingAgreement',
                          'PostCrisisReview', 'EmergencyDisposition')
        
        $coreModules = @('PersonHistory', 'PersonProfile', 'StaffModule', 'OrganizationModule',
                        'MessageModule', 'ProgressNote', 'Notification', 'Announcement')
        
        # Determine which tests to run
        $executionMode = '${{ parameters.ExecutionMode }}'
        $selectedTests = @()
        
        Write-Host "Execution Mode: $executionMode"
        Write-Host ""
        
        switch ($executionMode) {
          'RunAll' {
            $selectedTests = $allTests
            Write-Host "✓ Running ALL tests ($($allTests.Count) tests)"
          }
          'SelectIndividual' {
            if ('${{ parameters.PersonHistory }}' -eq 'True') { $selectedTests += 'PersonHistory' }
            if ('${{ parameters.ProfilePicture }}' -eq 'True') { $selectedTests += 'ProfilePicture' }
            if ('${{ parameters.MessageModule }}' -eq 'True') { $selectedTests += 'MessageModule' }
            if ('${{ parameters.ProgressNote }}' -eq 'True') { $selectedTests += 'ProgressNote' }
            if ('${{ parameters.Notification }}' -eq 'True') { $selectedTests += 'Notification' }
            if ('${{ parameters.PostCrisisReview }}' -eq 'True') { $selectedTests += 'PostCrisisReview' }
            if ('${{ parameters.ProgramApplication }}' -eq 'True') { $selectedTests += 'ProgramApplication' }
            if ('${{ parameters.ProgramConfig }}' -eq 'True') { $selectedTests += 'ProgramConfig' }
            if ('${{ parameters.Announcement }}' -eq 'True') { $selectedTests += 'Announcement' }
            if ('${{ parameters.StaffModule }}' -eq 'True') { $selectedTests += 'StaffModule' }
            if ('${{ parameters.OrganizationModule }}' -eq 'True') { $selectedTests += 'OrganizationModule' }
            if ('${{ parameters.PersonProfile }}' -eq 'True') { $selectedTests += 'PersonProfile' }
            if ('${{ parameters.ReportableEvents }}' -eq 'True') { $selectedTests += 'ReportableEvents' }
            if ('${{ parameters.ServiceDef_01 }}' -eq 'True') { $selectedTests += 'ServiceDef_01' }
            if ('${{ parameters.ServiceDef_02 }}' -eq 'True') { $selectedTests += 'ServiceDef_02' }
            if ('${{ parameters.ProgramEnrollmentNew }}' -eq 'True') { $selectedTests += 'ProgramEnrollmentNew' }
            if ('${{ parameters.SystemAttachments }}' -eq 'True') { $selectedTests += 'SystemAttachments' }
            if ('${{ parameters.AttachmentsModule }}' -eq 'True') { $selectedTests += 'AttachmentsModule' }
            if ('${{ parameters.BMP }}' -eq 'True') { $selectedTests += 'BMP' }
            if ('${{ parameters.BulkAssignment }}' -eq 'True') { $selectedTests += 'BulkAssignment' }
            if ('${{ parameters.CrisisBedIntakePacket }}' -eq 'True') { $selectedTests += 'CrisisBedIntakePacket' }
            if ('${{ parameters.CrisisHousingAssessment }}' -eq 'True') { $selectedTests += 'CrisisHousingAssessment' }
            if ('${{ parameters.CrisisIntake }}' -eq 'True') { $selectedTests += 'CrisisIntake' }
            if ('${{ parameters.CrisisHomeIntake }}' -eq 'True') { $selectedTests += 'CrisisHomeIntake' }
            if ('${{ parameters.CrisisTemporaryHousing }}' -eq 'True') { $selectedTests += 'CrisisTemporaryHousing' }
            if ('${{ parameters.CrisisHousingAgreement }}' -eq 'True') { $selectedTests += 'CrisisHousingAgreement' }
            if ('${{ parameters.DeathandMortality }}' -eq 'True') { $selectedTests += 'DeathandMortality' }
            if ('${{ parameters.EmergencyDisposition }}' -eq 'True') { $selectedTests += 'EmergencyDisposition' }
            if ('${{ parameters.GrievanceAppeal_01 }}' -eq 'True') { $selectedTests += 'GrievanceAppeal_01' }
            if ('${{ parameters.GrievanceAppeal_02 }}' -eq 'True') { $selectedTests += 'GrievanceAppeal_02' }
            if ('${{ parameters.Help }}' -eq 'True') { $selectedTests += 'Help' }
            if ('${{ parameters.LocationsModule }}' -eq 'True') { $selectedTests += 'LocationsModule' }
            if ('${{ parameters.IndividualSupportTeam }}' -eq 'True') { $selectedTests += 'IndividualSupportTeam' }
            if ('${{ parameters.MiniPCP }}' -eq 'True') { $selectedTests += 'MiniPCP' }
            if ('${{ parameters.ConfigDashboard }}' -eq 'True') { $selectedTests += 'ConfigDashboard' }
            if ('${{ parameters.PersonMaintenance }}' -eq 'True') { $selectedTests += 'PersonMaintenance' }
            
            Write-Host "✓ Running SELECTED tests ($($selectedTests.Count) tests)"
          }
          'SmokeTests' {
            $selectedTests = $smokeTests
            Write-Host "✓ Running SMOKE tests ($($smokeTests.Count) tests)"
          }
          'CriticalPath' {
            $selectedTests = $criticalPath
            Write-Host "✓ Running CRITICAL PATH tests ($($criticalPath.Count) tests)"
          }
          'CrisisModules' {
            $selectedTests = $crisisModules
            Write-Host "✓ Running CRISIS MODULE tests ($($crisisModules.Count) tests)"
          }
          'CoreModules' {
            $selectedTests = $coreModules
            Write-Host "✓ Running CORE MODULE tests ($($coreModules.Count) tests)"
          }
        }
        
        if ($selectedTests.Count -eq 0) {
          Write-Host "##vso[task.logissue type=error]No tests selected."
          exit 1
        }
        
        Write-Host ""
        Write-Host "📋 Selected Tests:"
        $selectedTests | Sort-Object | ForEach-Object { Write-Host "   • $_" }
        Write-Host ""
        
        # Calculate the number of child-pipeline batches that will be needed
        $maxParallel = ${{ parameters.MaxParallelTests }}
        $batchCount = [Math]::Ceiling($selectedTests.Count / $maxParallel)
        
        Write-Host "⚙️  Max Parallel: $maxParallel"
        Write-Host "📦 Total Batches Needed: $batchCount"
        Write-Host ""
        
        # Create target directory
        $basePath = "${{ parameters.targetPath }}"
        $newTargetPath = "$basePath\$(Build.DefinitionName)\$(Build.BuildId)"
        
        New-Item -ItemType Directory -Force -Path $newTargetPath | Out-Null
        Write-Host "✓ Created: $newTargetPath"

        # Create dedicated result folders for each selected test
        foreach ($test in $selectedTests) {
          $buildDefinition = $testDefinitions[$test]
          if (-not $buildDefinition) {
            Write-Host "##vso[task.logissue type=error]Missing child pipeline definition for test '$test'."
            exit 1
          }

          $resultPath = "$newTargetPath\$test"
          New-Item -ItemType Directory -Force -Path $resultPath | Out-Null

          @(
            "TestName: $test"
            "BuildDefinition: $buildDefinition"
            "RequestedByBuildId: $(Build.BuildId)"
          ) | Set-Content -Path (Join-Path $resultPath 'trigger-request.txt')

        }
        
        # Set variables
        Write-Host "##vso[task.setvariable variable=tPath;isOutput=true]$newTargetPath"
        Write-Host "##vso[task.setvariable variable=selectedTests;isOutput=true]$($selectedTests -join ',')"
        Write-Host "##vso[task.setvariable variable=batchCount;isOutput=true]$batchCount"
        
      name: setup
      displayName: 'Validate and Setup'

#############################################################################
# STAGE 2: TRIGGER TESTS IN PARALLEL - SINGLE PARENT ORCHESTRATOR
#############################################################################
- stage: TriggerTests
  displayName: '🚀 Trigger Test Pipelines (Parallel Execution)'
  dependsOn: Setup
  variables:
    tPath: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.tPath'] ]
    selectedTests: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.selectedTests'] ]
    batchCount: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.batchCount'] ]
  jobs:
  - job: OrchestrateChildPipelines
    displayName: 'Queue and Track Child Pipelines'
    pool:
      name: Interactive
    timeoutInMinutes: 480
    steps:
    - checkout: none

    - powershell: |
        Write-Host "========================================="
        Write-Host "CHILD PIPELINE ORCHESTRATOR"
        Write-Host "========================================="
        Write-Host "Requested Max Parallel: ${{ parameters.MaxParallelTests }}"
        Write-Host "Selected Tests: $(selectedTests)"
        Write-Host "Result Root: $(tPath)"

        $organizationUrl = "$(orgUrl)"
        $projectName = "$(projectName)"
        $sourceBranch = "$(Build.SourceBranch)"
        $pollIntervalSeconds = 30
        $maxParallel = [int]'${{ parameters.MaxParallelTests }}'
        $hasFailedChildren = $false
        $hasPartialChildren = $false
        $definitionCache = @{}
        $testDefinitions = @{
          'PersonHistory' = 'Test_Auto_STND_Regression_PersonHistory'
          'ProfilePicture' = 'Test_Auto_STND_Regression_ProfilePicture'
          'MessageModule' = 'Test_Auto_STND_Regression_MessageModule'
          'ProgressNote' = 'Test_Auto_STND_Regression_ProgressNote'
          'Notification' = 'Test_Auto_STND_Regression_Notification'
          'PostCrisisReview' = 'Test_Auto_STND_Regression_PostCrisisReview'
          'ProgramApplication' = 'Test_Auto_STND_Regression_ProgramApplication'
          'ProgramConfig' = 'Carity_STD_F1_RegressionTest_ProgramConfig'
          'Announcement' = 'Test_Auto_STND_Regression_Annoucement'
          'StaffModule' = 'Test_Auto_STND_Regression_StaffModule'
          'OrganizationModule' = 'Test_Auto_Regression_OrganizationModule_CommonBrowser'
          'PersonProfile' = 'Carity_Std_QC_RegressionTest_Person Profile (SOGI)'
          'ReportableEvents' = 'Test_Auto_STND_Regression_Reportable_Events'
          'ServiceDef_01' = 'Test_Auto_STND_Regression_ServiceDef_01'
          'ServiceDef_02' = 'Test_Auto_STND_Regression_ServiceDef_02'
          'ProgramEnrollmentNew' = 'Carity_Std_f1_RegressionTest_ProgramEnrollmentNew'
          'SystemAttachments' = 'Test_Auto_STND_Regression_SystemAttachments'
          'AttachmentsModule' = 'Test_Auto_STND_Regression_AttachmentsModule'
          'BMP' = 'Test_Auto_STND_Regression_BMP'
          'BulkAssignment' = 'Carity_Std_qc_RegressionTest_BulkAssignment'
          'CrisisBedIntakePacket' = 'Carity_STND_RegressionTest_CrisisBedIntakePacket'
          'CrisisHousingAssessment' = 'Carity_STND_RegressionTest_Crisis_Housing_Assessment'
          'CrisisIntake' = 'Carity_STND_RegressionTest_Crisis_Intake'
          'CrisisHomeIntake' = 'Carity_Std_CrisisHomeIntakeModule'
          'CrisisTemporaryHousing' = 'Carity_STND_RegressionTest_Crisis_Temporary_Housing'
          'CrisisHousingAgreement' = 'Carity_STND_RegressionTest_Crisis_Housing_Agreement'
          'DeathandMortality' = 'Test_Auto_STND_Regression_DeathandMortality'
          'EmergencyDisposition' = 'Test_Auto_STND_Regression_EmergencyDisposition'
          'GrievanceAppeal_01' = 'Test_Auto_STND_Regression_GrievanceAppeal_01'
          'GrievanceAppeal_02' = 'Test_Auto_STND_Regression_GrievanceAppeal_02'
          'Help' = 'Test_Auto_STND_Regression_Help'
          'LocationsModule' = 'Test_Auto_STND_Regression_LocationsModule'
          'IndividualSupportTeam' = 'Test_Auto_STND_Regression_IndividualSupportTeam'
          'MiniPCP' = 'Carity_STND_Regression Test_Mini PCP_F1'
          'ConfigDashboard' = 'Carity_STDF1_Config Dashboard'
          'PersonMaintenance' = 'Carity_Std_f1_RegressionTest_PersonMaintenance'
        }

        if (-not $env:ADO_PAT) {
          Write-Host "##vso[task.logissue type=error]sharedpat is not available."
          exit 1
        }

        $base64Auth = [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes(":$($env:ADO_PAT)"))
        $headers = @{
          Authorization = "Basic $base64Auth"
          'Content-Type' = 'application/json'
        }

        $selectedTests = @("$(selectedTests)".Split(',', [System.StringSplitOptions]::RemoveEmptyEntries))
        $testPlan = @()
        foreach ($testName in $selectedTests) {
          $trimmedTestName = $testName.Trim()
          $buildDefinition = $testDefinitions[$trimmedTestName]
          if (-not $buildDefinition) {
            Write-Host "##vso[task.logissue type=error]Missing child pipeline definition for test '$trimmedTestName'."
            exit 1
          }

          $testPlan += [pscustomobject]@{
            testName = $trimmedTestName
            buildDefinition = $buildDefinition
            resultPath = "$(tPath)\$trimmedTestName"
          }
        }

        if ($testPlan.Count -eq 0) {
          Write-Host "##vso[task.logissue type=error]No child pipelines were queued for orchestration."
          exit 1
        }

        function Get-BuildDefinitionId {
          param(
            [string]$DefinitionName
          )

          if ($definitionCache.ContainsKey($DefinitionName)) {
            return $definitionCache[$DefinitionName]
          }

          $encodedName = [Uri]::EscapeDataString($DefinitionName)
          $definitionUrl = "$organizationUrl$projectName/_apis/build/definitions?name=$encodedName&api-version=6.1-preview.7"
          $response = Invoke-RestMethod -Method Get -Uri $definitionUrl -Headers $headers
          $definition = $response.value | Where-Object { $_.name -eq $DefinitionName } | Select-Object -First 1

          if (-not $definition) {
            throw "Unable to locate child pipeline definition '$DefinitionName'."
          }

          $definitionCache[$DefinitionName] = $definition.id
          return $definition.id
        }

        function Queue-ChildPipeline {
          param(
            [pscustomobject]$TestItem
          )

          $definitionId = Get-BuildDefinitionId -DefinitionName $TestItem.buildDefinition
          $queueUrl = "$organizationUrl$projectName/_apis/build/builds?api-version=6.1-preview.7"
          $parameterObject = @{
            xPath = $TestItem.resultPath
            Browser = '${{ parameters.Browser }}'
            Environment = '${{ parameters.Environment }}'
          }
          $queueBody = @{
            definition = @{
              id = $definitionId
            }
            sourceBranch = $sourceBranch
            parameters = ($parameterObject | ConvertTo-Json -Compress)
          } | ConvertTo-Json -Depth 10

          $queuedBuild = Invoke-RestMethod -Method Post -Uri $queueUrl -Headers $headers -ContentType 'application/json' -Body $queueBody

          @(
            "TestName: $($TestItem.testName)"
            "BuildDefinition: $($TestItem.buildDefinition)"
            "BuildId: $($queuedBuild.id)"
            "QueueTime: $($queuedBuild.queueTime)"
            "SourceBranch: $sourceBranch"
          ) | Set-Content -Path (Join-Path $TestItem.resultPath 'trigger-queue.txt')

          Write-Host "Queued $($TestItem.testName) as build $($queuedBuild.id)"

          return [pscustomobject]@{
            testName = $TestItem.testName
            buildDefinition = $TestItem.buildDefinition
            resultPath = $TestItem.resultPath
            buildId = $queuedBuild.id
          }
        }

        function Get-BuildRunState {
          param(
            [int]$BuildId
          )

          $statusUrl = "$organizationUrl$projectName/_apis/build/builds/$BuildId?api-version=6.1-preview.7"
          return Invoke-RestMethod -Method Get -Uri $statusUrl -Headers $headers
        }

        $pendingItems = New-Object System.Collections.Queue
        foreach ($item in $testPlan) {
          $pendingItems.Enqueue([pscustomobject]@{
            testName = $item.testName
            buildDefinition = $item.buildDefinition
            resultPath = $item.resultPath
          })
        }

        $runningItems = @()
        $completedItems = @()

        while ($pendingItems.Count -gt 0 -or $runningItems.Count -gt 0) {
          while ($pendingItems.Count -gt 0 -and $runningItems.Count -lt $maxParallel) {
            $nextItem = $pendingItems.Dequeue()
            $runningItems += Queue-ChildPipeline -TestItem $nextItem
          }

          if ($runningItems.Count -eq 0) {
            break
          }

          Write-Host "Waiting on $($runningItems.Count) child pipeline(s); $($pendingItems.Count) remaining in queue."
          Start-Sleep -Seconds $pollIntervalSeconds

          $stillRunning = @()
          foreach ($runningItem in $runningItems) {
            $buildState = Get-BuildRunState -BuildId $runningItem.buildId
            if ($buildState.status -eq 'completed') {
              $result = if ($buildState.result) { $buildState.result } else { 'unknown' }
              @(
                "TestName: $($runningItem.testName)"
                "BuildDefinition: $($runningItem.buildDefinition)"
                "BuildId: $($runningItem.buildId)"
                "Status: $($buildState.status)"
                "Result: $result"
                "BuildNumber: $($buildState.buildNumber)"
                "FinishTime: $($buildState.finishTime)"
                "BuildUrl: $($buildState._links.web.href)"
              ) | Set-Content -Path (Join-Path $runningItem.resultPath 'trigger-status.txt')

              switch ($result) {
                'failed' { $hasFailedChildren = $true }
                'canceled' { $hasFailedChildren = $true }
                'partiallySucceeded' { $hasPartialChildren = $true }
              }

              Write-Host "Completed $($runningItem.testName) with result '$result'."
              $completedItems += [pscustomobject]@{
                testName = $runningItem.testName
                buildId = $runningItem.buildId
                result = $result
              }
            } else {
              $stillRunning += $runningItem
            }
          }

          $runningItems = $stillRunning
        }

        $summaryPath = Join-Path '$(tPath)' 'orchestration-summary.txt'
        @(
          "Requested Max Parallel: $maxParallel"
          "Selected Tests: $(selectedTests)"
          "Completed Count: $($completedItems.Count)"
          "Has Partial Children: $hasPartialChildren"
          "Has Failed Children: $hasFailedChildren"
        ) | Set-Content -Path $summaryPath

        if ($hasPartialChildren) {
          Write-Host "##vso[task.logissue type=warning]One or more child pipelines completed with partial success."
        }

        if ($hasFailedChildren) {
          Write-Host "##vso[task.logissue type=error]One or more child pipelines failed or were canceled."
          exit 1
        }
      displayName: 'Queue and Track Child Pipelines'
      env:
        ADO_PAT: $(sharedpat)

#############################################################################
# STAGE 3: CONSOLIDATE RESULTS
#############################################################################
- stage: ConsolidateResults
  displayName: '📊 Consolidate Results'
  dependsOn: 
  - Setup
  - TriggerTests
  condition: always()
  variables:
    tPath: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.tPath'] ]
  jobs:
  - job: PublishResults
    displayName: 'Analyze and Publish Results'
    timeoutInMinutes: 60
    pool:
      name: Interactive
    steps:
    - checkout: none
    
    - powershell: |
        $targetPath = "$(tPath)"
        
        Write-Host "========================================="
        Write-Host "📊 FINAL RESULTS ANALYSIS"
        Write-Host "========================================="
        Write-Host "Path: $targetPath"
        Write-Host ""
        
        # Wait a bit for final files
        Write-Host "⏳ Waiting 30 seconds for final file writes..."
        Start-Sleep -Seconds 30
        
        if (Test-Path $targetPath) {
            $allFiles = Get-ChildItem -Path $targetPath -Recurse -File -ErrorAction SilentlyContinue
            $totalFiles = $allFiles.Count
            $totalSizeMB = [math]::Round(($allFiles | Measure-Object -Property Length -Sum).Sum / 1MB, 2)
            
            Write-Host "📈 Overall Summary:"
            Write-Host "   Total Files: $totalFiles"
            Write-Host "   Total Size: $totalSizeMB MB"
            Write-Host ""
            
            # Analyze by test module
            $testFolders = Get-ChildItem -Path $targetPath -Directory -ErrorAction SilentlyContinue
            if ($testFolders.Count -gt 0) {
                Write-Host "📁 Results by Test Module:"
                Write-Host ("   {0,-35} {1,10} {2,12}" -f "Module", "Files", "Size (MB)")
                Write-Host ("   {0,-35} {1,10} {2,12}" -f "------", "-----", "---------")
                
                foreach ($folder in $testFolders | Sort-Object Name) {
                    $folderFiles = Get-ChildItem -Path $folder.FullName -Recurse -File -ErrorAction SilentlyContinue
                    $folderSizeMB = [math]::Round(($folderFiles | Measure-Object -Property Length -Sum).Sum / 1MB, 2)
                    Write-Host ("   {0,-35} {1,10} {2,12}" -f $folder.Name, $folderFiles.Count, $folderSizeMB)
                }
                
                Write-Host ""
                Write-Host "   Total Modules: $($testFolders.Count)"
            }
            
        } else {
            Write-Host "❌ Results path not found: $targetPath"
        }
        
        Write-Host ""
        Write-Host "========================================="
      displayName: 'Analyze Results'
    
    - task: PublishBuildArtifacts@1
      displayName: 'Publish Results'
      inputs:
        pathToPublish: '$(tPath)'
        artifactName: 'RegressionTestResults'
        publishLocation: 'Container'
      condition: always()
    
    - powershell: |
        Write-Host "========================================="
        Write-Host "✅ EXECUTION SUMMARY"
        Write-Host "========================================="
        Write-Host "Environment: ${{ parameters.Environment }}"
        Write-Host "Browser: ${{ parameters.Browser }}"
        Write-Host "Mode: ${{ parameters.ExecutionMode }}"
        Write-Host "Max Parallel: ${{ parameters.MaxParallelTests }}"
        Write-Host ""
        Write-Host "Results: $(tPath)"
        Write-Host "Artifact: RegressionTestResults"
        Write-Host "========================================="
      displayName: 'Summary'
