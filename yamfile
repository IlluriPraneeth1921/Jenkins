    value: $(System.TeamFoundationCollectionUri)
  - name: projectName
    value: $(System.TeamProject)

stages:
#############################################################################
# STAGE 1: SETUP AND VALIDATION
#############################################################################
- stage: Setup
  displayName: '🔧 Setup and Validation'
  jobs:
  - job: ValidateAndPrepare
    displayName: 'Validate Parameters and Create Target Directory'
    pool:
      name: Interactive
    timeoutInMinutes: 30
    steps:
    - checkout: none
    
    - powershell: |
        Write-Host "========================================="
        Write-Host "PARAMETER VALIDATION & TEST SELECTION"
        Write-Host "========================================="
        
        # Define all available tests
        $allTests = @(
          'PersonHistory', 'ProfilePicture', 'MessageModule', 'ProgressNote',
          'Notification', 'PostCrisisReview', 'ProgramApplication', 'ProgramConfig',
          'Announcement', 'StaffModule', 'OrganizationModule', 'PersonProfile',
          'ReportableEvents', 'ServiceDef_01', 'ServiceDef_02', 'ProgramEnrollmentNew',
          'SystemAttachments', 'AttachmentsModule', 'BMP', 'BulkAssignment',
          'CrisisBedIntakePacket', 'CrisisHousingAssessment', 'CrisisIntake',
          'CrisisHomeIntake', 'CrisisTemporaryHousing', 'CrisisHousingAgreement',
          'DeathandMortality', 'EmergencyDisposition', 'GrievanceAppeal_01',
          'GrievanceAppeal_02', 'Help', 'LocationsModule', 'IndividualSupportTeam',
          'MiniPCP', 'ConfigDashboard', 'PersonMaintenance'
        )
        
        # Predefined test groups
        $smokeTests = @('PersonHistory', 'MessageModule', 'ProgressNote', 'StaffModule', 'OrganizationModule')
        
        $criticalPath = @('PersonProfile', 'ProgramEnrollmentNew', 'ServiceDef_01', 
                         'ProgressNote', 'StaffModule', 'OrganizationModule', 'ReportableEvents')
        
        $crisisModules = @('CrisisBedIntakePacket', 'CrisisHousingAssessment', 'CrisisIntake',
                          'CrisisHomeIntake', 'CrisisTemporaryHousing', 'CrisisHousingAgreement',
                          'PostCrisisReview', 'EmergencyDisposition')
        
        $coreModules = @('PersonHistory', 'PersonProfile', 'StaffModule', 'OrganizationModule',
                        'MessageModule', 'ProgressNote', 'Notification', 'Announcement')
        
        # Determine which tests to run
        $executionMode = '${{ parameters.ExecutionMode }}'
        $selectedTests = @()
        
        Write-Host "Execution Mode: $executionMode"
        Write-Host ""
        
        switch ($executionMode) {
          'RunAll' {
            $selectedTests = $allTests
            Write-Host "✓ Running ALL tests ($($allTests.Count) tests)"
          }
          'SelectIndividual' {
            if ('${{ parameters.PersonHistory }}' -eq 'True') { $selectedTests += 'PersonHistory' }
            if ('${{ parameters.ProfilePicture }}' -eq 'True') { $selectedTests += 'ProfilePicture' }
            if ('${{ parameters.MessageModule }}' -eq 'True') { $selectedTests += 'MessageModule' }
            if ('${{ parameters.ProgressNote }}' -eq 'True') { $selectedTests += 'ProgressNote' }
            if ('${{ parameters.Notification }}' -eq 'True') { $selectedTests += 'Notification' }
            if ('${{ parameters.PostCrisisReview }}' -eq 'True') { $selectedTests += 'PostCrisisReview' }
            if ('${{ parameters.ProgramApplication }}' -eq 'True') { $selectedTests += 'ProgramApplication' }
            if ('${{ parameters.ProgramConfig }}' -eq 'True') { $selectedTests += 'ProgramConfig' }
            if ('${{ parameters.Announcement }}' -eq 'True') { $selectedTests += 'Announcement' }
            if ('${{ parameters.StaffModule }}' -eq 'True') { $selectedTests += 'StaffModule' }
            if ('${{ parameters.OrganizationModule }}' -eq 'True') { $selectedTests += 'OrganizationModule' }
            if ('${{ parameters.PersonProfile }}' -eq 'True') { $selectedTests += 'PersonProfile' }
            if ('${{ parameters.ReportableEvents }}' -eq 'True') { $selectedTests += 'ReportableEvents' }
            if ('${{ parameters.ServiceDef_01 }}' -eq 'True') { $selectedTests += 'ServiceDef_01' }
            if ('${{ parameters.ServiceDef_02 }}' -eq 'True') { $selectedTests += 'ServiceDef_02' }
            if ('${{ parameters.ProgramEnrollmentNew }}' -eq 'True') { $selectedTests += 'ProgramEnrollmentNew' }
            if ('${{ parameters.SystemAttachments }}' -eq 'True') { $selectedTests += 'SystemAttachments' }
            if ('${{ parameters.AttachmentsModule }}' -eq 'True') { $selectedTests += 'AttachmentsModule' }
            if ('${{ parameters.BMP }}' -eq 'True') { $selectedTests += 'BMP' }
            if ('${{ parameters.BulkAssignment }}' -eq 'True') { $selectedTests += 'BulkAssignment' }
            if ('${{ parameters.CrisisBedIntakePacket }}' -eq 'True') { $selectedTests += 'CrisisBedIntakePacket' }
            if ('${{ parameters.CrisisHousingAssessment }}' -eq 'True') { $selectedTests += 'CrisisHousingAssessment' }
            if ('${{ parameters.CrisisIntake }}' -eq 'True') { $selectedTests += 'CrisisIntake' }
            if ('${{ parameters.CrisisHomeIntake }}' -eq 'True') { $selectedTests += 'CrisisHomeIntake' }
            if ('${{ parameters.CrisisTemporaryHousing }}' -eq 'True') { $selectedTests += 'CrisisTemporaryHousing' }
            if ('${{ parameters.CrisisHousingAgreement }}' -eq 'True') { $selectedTests += 'CrisisHousingAgreement' }
            if ('${{ parameters.DeathandMortality }}' -eq 'True') { $selectedTests += 'DeathandMortality' }
            if ('${{ parameters.EmergencyDisposition }}' -eq 'True') { $selectedTests += 'EmergencyDisposition' }
            if ('${{ parameters.GrievanceAppeal_01 }}' -eq 'True') { $selectedTests += 'GrievanceAppeal_01' }
            if ('${{ parameters.GrievanceAppeal_02 }}' -eq 'True') { $selectedTests += 'GrievanceAppeal_02' }
            if ('${{ parameters.Help }}' -eq 'True') { $selectedTests += 'Help' }
            if ('${{ parameters.LocationsModule }}' -eq 'True') { $selectedTests += 'LocationsModule' }
            if ('${{ parameters.IndividualSupportTeam }}' -eq 'True') { $selectedTests += 'IndividualSupportTeam' }
            if ('${{ parameters.MiniPCP }}' -eq 'True') { $selectedTests += 'MiniPCP' }
            if ('${{ parameters.ConfigDashboard }}' -eq 'True') { $selectedTests += 'ConfigDashboard' }
            if ('${{ parameters.PersonMaintenance }}' -eq 'True') { $selectedTests += 'PersonMaintenance' }
            
            Write-Host "✓ Running SELECTED tests ($($selectedTests.Count) tests)"
          }
          'SmokeTests' {
            $selectedTests = $smokeTests
            Write-Host "✓ Running SMOKE tests ($($smokeTests.Count) tests)"
          }
          'CriticalPath' {
            $selectedTests = $criticalPath
            Write-Host "✓ Running CRITICAL PATH tests ($($criticalPath.Count) tests)"
          }
          'CrisisModules' {
            $selectedTests = $crisisModules
            Write-Host "✓ Running CRISIS MODULE tests ($($crisisModules.Count) tests)"
          }
          'CoreModules' {
            $selectedTests = $coreModules
            Write-Host "✓ Running CORE MODULE tests ($($coreModules.Count) tests)"
          }
        }
        
        if ($selectedTests.Count -eq 0) {
          Write-Host "##vso[task.logissue type=error]No tests selected."
          exit 1
        }
        
        Write-Host ""
        Write-Host "📋 Selected Tests:"
        $selectedTests | Sort-Object | ForEach-Object { Write-Host "   • $_" }
        Write-Host ""
        
        # Cap the number of child pipelines that can run at the same time.
        $maxParallel = [Math]::Max(1, [int]${{ parameters.MaxParallelTests }})
        $parallelChildCount = [Math]::Min($maxParallel, $selectedTests.Count)
        $batchCount = [Math]::Ceiling($selectedTests.Count / $parallelChildCount)
        
        Write-Host "⚙️  Max Parallel Requested: $maxParallel"
        Write-Host "🚀 Child Pipelines Running In Parallel: $parallelChildCount"
        Write-Host "📦 Execution Waves Needed: $batchCount"
        Write-Host ""
        
        # Create target directory
        $basePath = "${{ parameters.targetPath }}"
        $newTargetPath = "$basePath\$(Build.DefinitionName)\$(Build.BuildId)"
        
        New-Item -ItemType Directory -Force -Path $newTargetPath | Out-Null
        Write-Host "✓ Created: $newTargetPath"
        
        # Set variables
        Write-Host "##vso[task.setvariable variable=tPath;isOutput=true]$newTargetPath"
        Write-Host "##vso[task.setvariable variable=selectedTests;isOutput=true]$($selectedTests -join ',')"
        Write-Host "##vso[task.setvariable variable=batchCount;isOutput=true]$batchCount"
        Write-Host "##vso[task.setvariable variable=parallelChildCount;isOutput=true]$parallelChildCount"
        
      name: setup
      displayName: 'Validate and Setup'

#############################################################################
# STAGE 2: TRIGGER TESTS WITH A SINGLE MASTER CONTROLLER
#############################################################################
- stage: TriggerTests
  displayName: '🚀 Trigger Test Pipelines (Controlled Parallel Execution)'
  dependsOn: Setup
  variables:
    tPath: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.tPath'] ]
    selectedTests: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.selectedTests'] ]
    parallelChildCount: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.parallelChildCount'] ]
  jobs:
  - job: TriggerSelectedPipelines
    displayName: 'Queue Selected Child Pipelines'
    pool:
      name: Interactive
    timeoutInMinutes: 480
    steps:
    - checkout: none
    - powershell: |
        $selectedTestsRaw = "$(selectedTests)"
        $targetPath = "$(tPath)"
        $organizationUrl = "$(orgUrl)"
        $projectName = "$(projectName)"
        $parallelLimit = [Math]::Max(1, [int]"$(parallelChildCount)")
        $browser = '${{ parameters.Browser }}'
        $environment = '${{ parameters.Environment }}'
        $oauthToken = $env:SYSTEM_ACCESSTOKEN
        $patToken = "$(sharedpat)"
        
        if ([string]::IsNullOrWhiteSpace($selectedTestsRaw)) {
          Write-Host "No selected tests found."
          exit 0
        }
        
        $selectedTests = $selectedTestsRaw.Split(',', [System.StringSplitOptions]::RemoveEmptyEntries) | ForEach-Object { $_.Trim() }
        
        if ($selectedTests.Count -eq 0) {
          Write-Host "No selected tests found."
          exit 0
        }
        
        $pipelineMap = @{
          'PersonHistory'           = @{ Definition = 'Test_Auto_STND_Regression_PersonHistory'; XPath = "$targetPath\PersonHistory" }
          'ProfilePicture'          = @{ Definition = 'Test_Auto_STND_Regression_ProfilePicture'; XPath = "$targetPath\ProfilePicture" }
          'MessageModule'           = @{ Definition = 'Test_Auto_STND_Regression_MessageModule'; XPath = $targetPath }
          'ProgressNote'            = @{ Definition = 'Test_Auto_STND_Regression_ProgressNote'; XPath = $targetPath }
          'Notification'            = @{ Definition = 'Test_Auto_STND_Regression_Notification'; XPath = $targetPath }
          'PostCrisisReview'        = @{ Definition = 'Test_Auto_STND_Regression_PostCrisisReview'; XPath = $targetPath }
          'ProgramApplication'      = @{ Definition = 'Test_Auto_STND_Regression_ProgramApplication'; XPath = $targetPath }
          'ProgramConfig'           = @{ Definition = 'Carity_STD_F1_RegressionTest_ProgramConfig'; XPath = $targetPath }
          'Announcement'            = @{ Definition = 'Test_Auto_STND_Regression_Annoucement'; XPath = $targetPath }
          'StaffModule'             = @{ Definition = 'Test_Auto_STND_Regression_StaffModule'; XPath = $targetPath }
          'OrganizationModule'      = @{ Definition = 'Test_Auto_Regression_OrganizationModule_CommonBrowser'; XPath = $targetPath }
          'PersonProfile'           = @{ Definition = 'Carity_Std_QC_RegressionTest_Person Profile (SOGI)'; XPath = $targetPath }
          'ReportableEvents'        = @{ Definition = 'Test_Auto_STND_Regression_Reportable_Events'; XPath = $targetPath }
          'ServiceDef_01'           = @{ Definition = 'Test_Auto_STND_Regression_ServiceDef_01'; XPath = $targetPath }
          'ServiceDef_02'           = @{ Definition = 'Test_Auto_STND_Regression_ServiceDef_02'; XPath = $targetPath }
          'ProgramEnrollmentNew'    = @{ Definition = 'Carity_Std_f1_RegressionTest_ProgramEnrollmentNew'; XPath = $targetPath }
          'SystemAttachments'       = @{ Definition = 'Test_Auto_STND_Regression_SystemAttachments'; XPath = $targetPath }
          'AttachmentsModule'       = @{ Definition = 'Test_Auto_STND_Regression_AttachmentsModule'; XPath = $targetPath }
          'BMP'                     = @{ Definition = 'Test_Auto_STND_Regression_BMP'; XPath = $targetPath }
          'BulkAssignment'          = @{ Definition = 'Carity_Std_qc_RegressionTest_BulkAssignment'; XPath = $targetPath }
          'CrisisBedIntakePacket'   = @{ Definition = 'Carity_STND_RegressionTest_CrisisBedIntakePacket'; XPath = $targetPath }
          'CrisisHousingAssessment' = @{ Definition = 'Carity_STND_RegressionTest_Crisis_Housing_Assessment'; XPath = $targetPath }
          'CrisisIntake'            = @{ Definition = 'Carity_STND_RegressionTest_Crisis_Intake'; XPath = $targetPath }
          'CrisisHomeIntake'        = @{ Definition = 'Carity_Std_CrisisHomeIntakeModule'; XPath = $targetPath }
          'CrisisTemporaryHousing'  = @{ Definition = 'Carity_STND_RegressionTest_Crisis_Temporary_Housing'; XPath = $targetPath }
          'CrisisHousingAgreement'  = @{ Definition = 'Carity_STND_RegressionTest_Crisis_Housing_Agreement'; XPath = $targetPath }
          'DeathandMortality'       = @{ Definition = 'Test_Auto_STND_Regression_DeathandMortality'; XPath = $targetPath }
          'EmergencyDisposition'    = @{ Definition = 'Test_Auto_STND_Regression_EmergencyDisposition'; XPath = $targetPath }
          'GrievanceAppeal_01'      = @{ Definition = 'Test_Auto_STND_Regression_GrievanceAppeal_01'; XPath = $targetPath }
          'GrievanceAppeal_02'      = @{ Definition = 'Test_Auto_STND_Regression_GrievanceAppeal_02'; XPath = $targetPath }
          'Help'                    = @{ Definition = 'Test_Auto_STND_Regression_Help'; XPath = $targetPath }
          'LocationsModule'         = @{ Definition = 'Test_Auto_STND_Regression_LocationsModule'; XPath = $targetPath }
          'IndividualSupportTeam'   = @{ Definition = 'Test_Auto_STND_Regression_IndividualSupportTeam'; XPath = $targetPath }
          'MiniPCP'                 = @{ Definition = 'Carity_STND_Regression Test_Mini PCP_F1'; XPath = $targetPath }
          'ConfigDashboard'         = @{ Definition = 'Carity_STDF1_Config Dashboard'; XPath = $targetPath }
          'PersonMaintenance'       = @{ Definition = 'Carity_Std_f1_RegressionTest_PersonMaintenance'; XPath = $targetPath }
        }
        
        if (-not [string]::IsNullOrWhiteSpace($oauthToken)) {
          $authHeaders = @{ Authorization = "Bearer $oauthToken" }
        }
        elseif (-not [string]::IsNullOrWhiteSpace($patToken)) {
          $basicToken = [Convert]::ToBase64String([System.Text.Encoding]::ASCII.GetBytes(":$patToken"))
          $authHeaders = @{ Authorization = "Basic $basicToken" }
        }
        else {
          throw "No authentication token available to queue child pipelines."
        }
        
        $jsonHeaders = @{}
        foreach ($key in $authHeaders.Keys) {
          $jsonHeaders[$key] = $authHeaders[$key]
        }
        $jsonHeaders['Content-Type'] = 'application/json'
        
        $encodedProject = [System.Uri]::EscapeDataString($projectName)
        $definitionBaseUrl = "$organizationUrl$encodedProject/_apis/build/definitions"
        $buildBaseUrl = "$organizationUrl$encodedProject/_apis/build/builds"
        $definitionIdCache = @{}
        $pendingTests = [System.Collections.Generic.Queue[string]]::new()
        $activeBuilds = [System.Collections.Generic.List[object]]::new()
        $failures = [System.Collections.Generic.List[string]]::new()
        $pollSeconds = 30
        
        foreach ($testName in $selectedTests) {
          $pendingTests.Enqueue($testName)
        }
        
        function Get-DefinitionId {
          param(
            [string]$DefinitionName
          )
        
          if ($definitionIdCache.ContainsKey($DefinitionName)) {
            return $definitionIdCache[$DefinitionName]
          }
        
          $definitionLookupUrl = "{0}?name={1}&api-version=7.1" -f $definitionBaseUrl, [System.Uri]::EscapeDataString($DefinitionName)
          $definitionResponse = Invoke-RestMethod -Method Get -Uri $definitionLookupUrl -Headers $authHeaders
          if (-not $definitionResponse.value -or $definitionResponse.count -lt 1) {
            throw "Unable to locate child pipeline definition '$DefinitionName'."
          }
        
          $definitionIdCache[$DefinitionName] = $definitionResponse.value[0].id
          return $definitionIdCache[$DefinitionName]
        }
        
        function Queue-ChildPipeline {
          param(
            [string]$TestName
          )
        
          if (-not $pipelineMap.ContainsKey($TestName)) {
            throw "No child pipeline mapping found for '$TestName'."
          }
        
          $definitionName = $pipelineMap[$TestName].Definition
          $xPathValue = $pipelineMap[$TestName].XPath
          $definitionId = Get-DefinitionId -DefinitionName $definitionName
          $queueBody = @{
            definition = @{
              id = $definitionId
            }
            parameters = (@{
              xPath = $xPathValue
              Browser = $browser
              Environment = $environment
            } | ConvertTo-Json -Compress)
          } | ConvertTo-Json -Depth 5 -Compress
        
          $queuedBuild = Invoke-RestMethod -Method Post -Uri "$buildBaseUrl?api-version=7.1" -Headers $jsonHeaders -Body $queueBody
        
          return [pscustomobject]@{
            TestName       = $TestName
            DefinitionName = $definitionName
            BuildId        = [int]$queuedBuild.id
          }
        }
        
        function Get-ChildBuildStatus {
          param(
            [int]$BuildId
          )
        
          return Invoke-RestMethod -Method Get -Uri "$buildBaseUrl/$BuildId?api-version=7.1" -Headers $authHeaders
        }
        
        Write-Host "========================================="
        Write-Host "MASTER CONTROLLER"
        Write-Host "========================================="
        Write-Host "Selected child pipelines: $($selectedTests.Count)"
        Write-Host "Maximum child pipelines in parallel: $parallelLimit"
        Write-Host ""
        
        while ($pendingTests.Count -gt 0 -or $activeBuilds.Count -gt 0) {
          while ($pendingTests.Count -gt 0 -and $activeBuilds.Count -lt $parallelLimit) {
            $nextTest = $pendingTests.Dequeue()
        
            try {
              $childBuild = Queue-ChildPipeline -TestName $nextTest
              $activeBuilds.Add($childBuild)
              Write-Host "[$($childBuild.TestName)] queued build $($childBuild.BuildId). Active children: $($activeBuilds.Count)"
            }
            catch {
              $failures.Add("$nextTest => queue failed. $($_.Exception.Message)")
              Write-Host "##vso[task.logissue type=warning]$nextTest queue failed. $($_.Exception.Message)"
            }
          }
        
          if ($activeBuilds.Count -eq 0) {
            continue
          }
        
          Start-Sleep -Seconds $pollSeconds
        
          for ($index = $activeBuilds.Count - 1; $index -ge 0; $index--) {
            $activeBuild = $activeBuilds[$index]
        
            try {
              $buildStatus = Get-ChildBuildStatus -BuildId $activeBuild.BuildId
              Write-Host "[$($activeBuild.TestName)] build $($activeBuild.BuildId) status: $($buildStatus.status), result: $($buildStatus.result)"
        
              if ($buildStatus.status -eq 'completed') {
                if ($buildStatus.result -in @('succeeded', 'partiallySucceeded')) {
                  Write-Host "[$($activeBuild.TestName)] child pipeline completed successfully."
                }
                else {
                  $failures.Add("$($activeBuild.TestName) => completed with result '$($buildStatus.result)'")
                  Write-Host "##vso[task.logissue type=warning]$($activeBuild.TestName) completed with result '$($buildStatus.result)'."
                }
        
                $activeBuilds.RemoveAt($index)
              }
            }
            catch {
              $failures.Add("$($activeBuild.TestName) => status check failed. $($_.Exception.Message)")
              $activeBuilds.RemoveAt($index)
              Write-Host "##vso[task.logissue type=warning]$($activeBuild.TestName) status check failed. $($_.Exception.Message)"
            }
          }
        }
        
        if ($failures.Count -gt 0) {
          Write-Host ""
          Write-Host "Child pipeline failures:"
          $failures | ForEach-Object { Write-Host " - $_" }
          exit 1
        }
        
        Write-Host ""
        Write-Host "All selected child pipelines completed successfully."
      displayName: 'Queue and monitor child pipelines'
      env:
        SYSTEM_ACCESSTOKEN: $(System.AccessToken)

#############################################################################
# STAGE 3: CONSOLIDATE RESULTS
#############################################################################
- stage: ConsolidateResults
  displayName: '📊 Consolidate Results'
  dependsOn: 
  - Setup
  - TriggerTests
  condition: always()
  variables:
    tPath: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.tPath'] ]
    parallelChildCount: $[ stageDependencies.Setup.ValidateAndPrepare.outputs['setup.parallelChildCount'] ]
  jobs:
  - job: PublishResults
    displayName: 'Analyze and Publish Results'
    timeoutInMinutes: 60
    pool:
      name: Interactive
    steps:
    - checkout: none
    
    - powershell: |
        $targetPath = "$(tPath)"
        
        Write-Host "========================================="
        Write-Host "📊 FINAL RESULTS ANALYSIS"
        Write-Host "========================================="
        Write-Host "Path: $targetPath"
        Write-Host ""
        
        # Wait a bit for final files
        Write-Host "⏳ Waiting 30 seconds for final file writes..."
        Start-Sleep -Seconds 30
        
        if (Test-Path $targetPath) {
            $allFiles = Get-ChildItem -Path $targetPath -Recurse -File -ErrorAction SilentlyContinue
            $totalFiles = $allFiles.Count
            $totalSizeMB = [math]::Round(($allFiles | Measure-Object -Property Length -Sum).Sum / 1MB, 2)
            
            Write-Host "📈 Overall Summary:"
            Write-Host "   Total Files: $totalFiles"
            Write-Host "   Total Size: $totalSizeMB MB"
            Write-Host ""
            
            # Analyze by test module
            $testFolders = Get-ChildItem -Path $targetPath -Directory -ErrorAction SilentlyContinue
            if ($testFolders.Count -gt 0) {
                Write-Host "📁 Results by Test Module:"
                Write-Host ("   {0,-35} {1,10} {2,12}" -f "Module", "Files", "Size (MB)")
                Write-Host ("   {0,-35} {1,10} {2,12}" -f "------", "-----", "---------")
                
                foreach ($folder in $testFolders | Sort-Object Name) {
                    $folderFiles = Get-ChildItem -Path $folder.FullName -Recurse -File -ErrorAction SilentlyContinue
                    $folderSizeMB = [math]::Round(($folderFiles | Measure-Object -Property Length -Sum).Sum / 1MB, 2)
                    Write-Host ("   {0,-35} {1,10} {2,12}" -f $folder.Name, $folderFiles.Count, $folderSizeMB)
                }
                
                Write-Host ""
                Write-Host "   Total Modules: $($testFolders.Count)"
            }
            
        } else {
            Write-Host "❌ Results path not found: $targetPath"
        }
        
        Write-Host ""
        Write-Host "========================================="
      displayName: 'Analyze Results'
    
    - task: PublishBuildArtifacts@1
      displayName: 'Publish Results'
      inputs:
        pathToPublish: '$(tPath)'
        artifactName: 'RegressionTestResults'
        publishLocation: 'Container'
      condition: always()
    
    - powershell: |
        Write-Host "========================================="
        Write-Host "✅ EXECUTION SUMMARY"
        Write-Host "========================================="
        Write-Host "Environment: ${{ parameters.Environment }}"
        Write-Host "Browser: ${{ parameters.Browser }}"
        Write-Host "Mode: ${{ parameters.ExecutionMode }}"
        Write-Host "Requested Parallel Child Pipelines: ${{ parameters.MaxParallelTests }}"
        Write-Host "Actual Parallel Child Pipelines: $(parallelChildCount)"
        Write-Host ""
        Write-Host "Results: $(tPath)"
        Write-Host "Artifact: RegressionTestResults"
        Write-Host "========================================="
      displayName: 'Summary'
